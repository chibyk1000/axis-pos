{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:default",
    "fs:default", "fs:allow-copy-file",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "sql:default",
    "sql:allow-execute",
    "shell:default",
    "os:default",
 "dialog:allow-confirm",
    "fs:allow-exists",
    "fs:allow-temp-write",
    "fs:allow-temp-read",
    {
      "identifier": "opener:allow-open-path",
      "allow": [{ "path": "**" }]
    },
    {
      "identifier": "shell:allow-open",
      "allow": [{ "open": "^(.*)$" }]
    }, {
      "identifier": "fs:allow-copy-file",
      "allow": [
        {
          "path": "$APPDATA/com.axis-pos/**"
        }
      ]
    }
  ]
}
